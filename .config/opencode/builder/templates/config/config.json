{
    "$schema": "https://opencode.ai/config.json",
    "experimental": {
        "mcp_timeout": 3600000
    },
    "plugin": [
        "opencode-gemini-auth@latest",
        "opencode-snippets@latest",
        "opencode-snip@latest",
        "opencode-notify@latest",
        "envsitter-guard@latest",
        "@ykaratkou/opencode-worktree@0.1.0",
        "./plugins/graphify.js",
        "./plugins/engram.ts"
    ],
    "theme": "catppuccin",
    "autoupdate": true,
    "mcp": {
        "cw-ai-gateway": {
            "type": "local",
            "command": [
                "/usr/local/bin/mcp-k8s-proxy"
            ],
            "timeout": 3600000,
            "reconnect": true,
            "enabled": false
        },
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        },
        "atlassian": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@xuandev/atlassian-mcp"
            ],
            "environment": {
                "ATLASSIAN_DOMAIN": "${ATLASSIAN_DOMAIN}",
                "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}",
                "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
            },
            "_requires_env": [
                "ATLASSIAN_DOMAIN",
                "ATLASSIAN_EMAIL",
                "ATLASSIAN_API_TOKEN"
            ],
            "enabled": true
        },
        "tavily": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "tavily-mcp"
            ],
            "environment": {
                "TAVILY_API_KEY": "${TAVILY_API_KEY}"
            },
            "_requires_env": [
                "TAVILY_API_KEY"
            ],
            "enabled": true
        },
        "brave-search": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "environment": {
                "BRAVE_API_KEY": "${BRAVE_API_KEY}"
            },
            "_requires_env": [
                "BRAVE_API_KEY"
            ],
            "enabled": true
        },
        "mgrep": {
            "type": "local",
            "command": [
                "mgrep",
                "mcp"
            ],
            "environment": {
                "MXBAI_API_KEY": "${MXBAI_API_KEY}"
            },
            "_requires_env": [
                "MXBAI_API_KEY"
            ],
            "enabled": true
        },
        "engram": {
            "type": "local",
            "command": [
                "/home/andres/.local/bin/engram",
                "mcp",
                "--tools=agent"
            ],
            "enabled": true
        },
        "gh_grep": {
            "type": "remote",
            "url": "https://mcp.grep.app",
            "enabled": true
        },
        "postgres": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-postgres",
                "${POSTGRES_MCP_URL}"
            ],
            "environment": {
                "POSTGRES_MCP_URL": "${POSTGRES_MCP_URL}"
            },
            "_requires_env": [
                "POSTGRES_MCP_URL"
            ],
            "enabled": true
        },
        "redis": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@modelcontextprotocol/server-redis",
                "${REDIS_MCP_URL}"
            ],
            "environment": {
                "REDIS_MCP_URL": "${REDIS_MCP_URL}"
            },
            "_requires_env": [
                "REDIS_MCP_URL"
            ],
            "enabled": true
        }
    },
    "agent": {
        "build": {
            "disable": true
        },
        "plan": {
            "disable": true
        },
        "PE_build": {
            "disable": true
        },
        "PE_plan": {
            "disable": true
        }
    },
    "default_agent": "commander",
    "model": "{{MODEL:model}}",
    "small_model": "{{MODEL:small_model}}"
}
